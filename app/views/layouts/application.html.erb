<!DOCTYPE html>
<html>
  <head>
    <title><%= @title || "Invariant" %></title>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Sharpen how you think about distributed systems. Realistic incident simulations that train production judgment through consequence-based learning.">
    <meta name="keywords" content="distributed systems training, incident simulation, production judgment, reliability engineering, on-call training, SRE skills, infrastructure debugging">
    <meta name="theme-color" content="#4d5562">
    <meta name="msapplication-TileColor" content="#4d5562">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= @title || 'Invariant — Sharpen how you think about distributed systems' %>">
    <meta property="og:description" content="Sharpen how you think about distributed systems. Realistic incident simulations that train production judgment.">
    <%# <meta property="og:image" content="https://invariant.training/social.png"> %>
    <meta property="og:site_name" content="invariant.training">
    <meta property="og:locale" content="en_US">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:url" content="<%= request.original_url %>">
    <meta name="twitter:title" content="<%= @title || 'Invariant — Sharpen how you think about distributed systems' %>">
    <meta name="twitter:description" content="Sharpen how you think about distributed systems. Realistic incident simulations that train production judgment.">
    <%# <meta name="twitter:image" content="https://invariant.training/social.png"> %>

    <link rel="canonical" href="<%= request.original_url %>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rubik:ital,wght@0,300..900;1,300..900&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="manifest" href="/site.webmanifest">
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5">
    <link rel="preload" href="/fonts/SuisseIntl-Regular.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    <link rel="preload" href="/fonts/SuisseIntl-Semibold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    <link rel="preload" href="/fonts/SuisseIntl-Bold.woff2" as="font" type="font/woff2" crossorigin="anonymous">
    <%= stylesheet_link_tag "application", as: "style" %>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/vs2015.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/highlightjs-line-numbers.js/2.9.0/highlightjs-line-numbers.min.js"></script>
    <script src="/terraform.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        hljs.registerLanguage('terraform', hljsDefineTerraform);
        hljs.registerLanguage('hcl', hljsDefineTerraform);
        hljs.highlightAll();
        hljs.initLineNumbersOnLoad();
      });
    </script>
    <%= stylesheet_link_tag "tailwind", as: "style" %>
    <%= javascript_include_tag "application", defer: true %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="bg-zinc-900">
    <div class="h-screen w-screen overflow-hidden">
      <%= yield %>
    </div>
  </body>
</html>